<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Elevate.Pages.LoginPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0D0D0F" Offset="0.0" />
            <GradientStop Color="#1A1040" Offset="0.6" />
            <GradientStop Color="#0A2A2A" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,40" Spacing="0" VerticalOptions="Center">

            <!-- Logo -->
            <Border WidthRequest="90" HeightRequest="90"
                    StrokeThickness="0" StrokeShape="RoundRectangle 22"
                    HorizontalOptions="Center" Margin="0,0,0,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#6C63FF" Offset="0.0" />
                        <GradientStop Color="#00C9A7" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Label Text="⬆" FontSize="40" TextColor="White"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <Label Text="Elevate" FontSize="36" FontAttributes="Bold"
                   TextColor="White" HorizontalOptions="Center"/>
            <Label Text="Creator Growth Platform" FontSize="14"
                   TextColor="#9999BB" HorizontalOptions="Center" Margin="0,6,0,40"/>

            <!-- Tab Toggle -->
            <Border BackgroundColor="#1F1F1F" StrokeThickness="0"
                    StrokeShape="RoundRectangle 14" Padding="4" Margin="0,0,0,28">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="0">
                    <Border x:Name="LoginTabBg" Grid.Column="0" BackgroundColor="#6C63FF"
                            StrokeThickness="0" StrokeShape="RoundRectangle 10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLoginTabTapped"/>
                        </Border.GestureRecognizers>
                        <Label x:Name="LoginTabLabel" Text="Sign In" TextColor="White"
                               FontAttributes="Bold" HorizontalOptions="Center" Margin="0,10"/>
                    </Border>
                    <Border x:Name="RegisterTabBg" Grid.Column="1" BackgroundColor="Transparent"
                            StrokeThickness="0" StrokeShape="RoundRectangle 10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRegisterTabTapped"/>
                        </Border.GestureRecognizers>
                        <Label x:Name="RegisterTabLabel" Text="Register" TextColor="#888"
                               FontAttributes="Bold" HorizontalOptions="Center" Margin="0,10"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Login Form -->
            <VerticalStackLayout x:Name="LoginForm" Spacing="14">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Username or Email" TextColor="#AAAAAA" FontSize="13"/>
                    <Border Stroke="#333" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="14,4">
                        <Entry x:Name="LoginUsernameEntry" Placeholder="Enter username or email"
                               PlaceholderColor="#555" TextColor="White" BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Password" TextColor="#AAAAAA" FontSize="13"/>
                    <Border Stroke="#333" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="14,4">
                        <Entry x:Name="LoginPasswordEntry" Placeholder="Enter password"
                               PlaceholderColor="#555" TextColor="White" IsPassword="True"
                               BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <Label x:Name="LoginErrorLabel" Text="" TextColor="#FF7043"
                       FontSize="13" IsVisible="False" HorizontalOptions="Center"/>

                <Border BackgroundColor="#6C63FF" StrokeThickness="0"
                        StrokeShape="RoundRectangle 14" Padding="0,16" Margin="0,8,0,0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSignInTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="Sign In" TextColor="White" FontAttributes="Bold"
                           FontSize="17" HorizontalOptions="Center"/>
                </Border>
            </VerticalStackLayout>

            <!-- Register Form -->
            <VerticalStackLayout x:Name="RegisterForm" IsVisible="False" Spacing="14">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Display Name" TextColor="#AAAAAA" FontSize="13"/>
                    <Border Stroke="#333" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="14,4">
                        <Entry x:Name="RegDisplayNameEntry" Placeholder="Your name"
                               PlaceholderColor="#555" TextColor="White" BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Username" TextColor="#AAAAAA" FontSize="13"/>
                    <Border Stroke="#333" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="14,4">
                        <Entry x:Name="RegUsernameEntry" Placeholder="Choose a username"
                               PlaceholderColor="#555" TextColor="White" BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Email" TextColor="#AAAAAA" FontSize="13"/>
                    <Border Stroke="#333" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="14,4">
                        <Entry x:Name="RegEmailEntry" Placeholder="your@email.com"
                               PlaceholderColor="#555" TextColor="White" Keyboard="Email"
                               BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Password" TextColor="#AAAAAA" FontSize="13"/>
                    <Border Stroke="#333" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="14,4">
                        <Entry x:Name="RegPasswordEntry" Placeholder="At least 6 characters"
                               PlaceholderColor="#555" TextColor="White" IsPassword="True"
                               BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <Label x:Name="RegErrorLabel" Text="" TextColor="#FF7043"
                       FontSize="13" IsVisible="False" HorizontalOptions="Center"/>

                <Border BackgroundColor="#6C63FF" StrokeThickness="0"
                        StrokeShape="RoundRectangle 14" Padding="0,16" Margin="0,8,0,0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRegisterTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="Create Account" TextColor="White" FontAttributes="Bold"
                           FontSize="17" HorizontalOptions="Center"/>
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
