<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Elevate.Pages.AlertsPage"
             BackgroundColor="#121212"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, Auto, *">
        <Grid Grid.Row="0" Padding="20,52,20,10" ColumnDefinitions="Auto, *, Auto">
            <Border Grid.Column="0" BackgroundColor="#222" StrokeShape="RoundRectangle 12" WidthRequest="40" HeightRequest="40">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped"/>
                </Border.GestureRecognizers>
                <Label Text="‹" FontSize="28" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" Margin="0,-2,0,0"/>
            </Border>

            <VerticalStackLayout Grid.Column="1" Margin="15,0">
                <Label x:Name="ClockLabel" Text="00:00 AM" FontSize="24" FontAttributes="Bold" TextColor="White"/>
                <Label x:Name="LockDateLabel" Text="Date" TextColor="#888" FontSize="13"/>
            </VerticalStackLayout>

            <HorizontalStackLayout Grid.Column="2" Spacing="10" VerticalOptions="Center">
                <Border x:Name="UnreadBadge" BackgroundColor="#6C63FF" Padding="8,2" StrokeShape="RoundRectangle 10" IsVisible="False">
                    <Label x:Name="UnreadBadgeText" Text="0" TextColor="White" FontSize="12" FontAttributes="Bold"/>
                </Border>
                <Label Text="Done" TextColor="#6C63FF" FontAttributes="Bold" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMarkAllReadTapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>
        </Grid>

        <Label Grid.Row="1" Text="Notifications" TextColor="White" FontAttributes="Bold" FontSize="18" Margin="20,10"/>

        <ScrollView Grid.Row="2">
            <VerticalStackLayout x:Name="AlertsListStack" Padding="20" Spacing="12" />
        </ScrollView>
    </Grid>
</ContentPage>