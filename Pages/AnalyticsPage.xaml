<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Elevate.Pages.AnalyticsPage"
             BackgroundColor="#121212"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">
        <Grid Grid.Row="0" Padding="20,52,20,10" ColumnDefinitions="Auto, *, Auto">
            <Border Grid.Column="0" BackgroundColor="#222" StrokeShape="RoundRectangle 12" WidthRequest="40" HeightRequest="40">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped"/>
                </Border.GestureRecognizers>
                <Label Text="‹" FontSize="28" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" Margin="0,-2,0,0"/>
            </Border>
            <Label Grid.Column="1" Text="Analytics" FontSize="24" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" Margin="15,0"/>
            <Label Grid.Column="2" Text="Share" TextColor="#00C9A7" FontAttributes="Bold" VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnShareTapped"/>
                </Label.GestureRecognizers>
            </Label>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20">

                <!-- ── Followers card ── -->
                <Border BackgroundColor="#1F1F1F" Padding="20" StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="👥  Total Followers" TextColor="#888" FontSize="13"/>
                        <Label x:Name="TotalFollowersLabel" Text="0" FontSize="32" FontAttributes="Bold" TextColor="White"/>
                        <Label x:Name="FollowerGrowthLabel" Text="↑ 0 since first entry" TextColor="#00C9A7" FontSize="14"/>

                        <Grid ColumnDefinitions="*,*" Margin="0,10,0,0">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="Daily Avg Gain" TextColor="#555" FontSize="11"/>
                                <Label x:Name="DailyGainLabel" Text="0" TextColor="White" FontAttributes="Bold"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="Growth Rate" TextColor="#555" FontSize="11"/>
                                <Label x:Name="GrowthRateLabel" Text="0%" TextColor="White" FontAttributes="Bold"/>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- ── Follower chart ── -->
                <Border BackgroundColor="#1F1F1F" Padding="20" StrokeShape="RoundRectangle 16" HeightRequest="180">
                    <Grid x:Name="SnapshotChartGrid" RowDefinitions="*, Auto"/>
                </Border>

                <!-- ── Likes card + Content card ── -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Grid.Column="0" BackgroundColor="#1F1F1F" Padding="16" StrokeShape="RoundRectangle 16">
                        <VerticalStackLayout>
                            <Label Text="❤️  Total Likes" TextColor="#888" FontSize="12"/>
                            <Label x:Name="TotalLikesLabel" Text="0" FontSize="20" FontAttributes="Bold" TextColor="White"/>
                            <Label x:Name="LikesChangeLabel" Text="last logged" TextColor="#E53935" FontSize="11"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" BackgroundColor="#1F1F1F" Padding="16" StrokeShape="RoundRectangle 16">
                        <VerticalStackLayout>
                            <Label Text="📅  Total Content" TextColor="#888" FontSize="12"/>
                            <Label x:Name="TotalPostsLabel" Text="0" FontSize="20" FontAttributes="Bold" TextColor="White"/>
                            <Label x:Name="CompletedPostsLabel" Text="0 completed" TextColor="#6C63FF" FontSize="11"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- ── Achievements card ── -->
                <Border BackgroundColor="#1F1F1F" Padding="16" StrokeShape="RoundRectangle 16">
                    <Grid ColumnDefinitions="*,*">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="🏆  Achievements" TextColor="#888" FontSize="12"/>
                            <Label x:Name="TotalAchievementsLabel" Text="0" FontSize="20" FontAttributes="Bold" TextColor="White"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Latest" TextColor="#555" FontSize="11"/>
                            <Label x:Name="LatestAchievementLabel" Text="None" TextColor="#B388FF" FontSize="13" FontAttributes="Bold" LineBreakMode="TailTruncation"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- ── Goal progress ── -->
                <Label Text="Goal Progress" TextColor="White" FontAttributes="Bold" FontSize="18" Margin="0,10,0,0"/>
                <VerticalStackLayout x:Name="GoalProgressStack" Spacing="15"/>

                <BoxView HeightRequest="40" Color="Transparent"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
